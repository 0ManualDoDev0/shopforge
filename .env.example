# =============================================================================
# Database
# =============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/shopforge"

# =============================================================================
# NextAuth / Auth.js
# =============================================================================
# Base URL of the application (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
# Secret used to sign JWTs and session cookies — generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# =============================================================================
# Google OAuth (optional — enables "Sign in with Google")
# =============================================================================
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# =============================================================================
# Stripe
# =============================================================================
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Publishable key (exposed to the browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — from the Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================================================
# UploadThing (file uploads)
# =============================================================================
# App ID and secret from https://uploadthing.com/dashboard
# Note: UploadThing v7+ also accepts a single UPLOADTHING_TOKEN (base64-encoded)
UPLOADTHING_APP_ID="..."
UPLOADTHING_SECRET="sk_live_..."

# =============================================================================
# Resend (transactional email)
# =============================================================================
# API key from https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Verified sender address (must match a domain verified in Resend)
RESEND_FROM_EMAIL="ShopForge <noreply@yourdomain.com>"

# =============================================================================
# Upstash Redis (rate limiting)
# =============================================================================
# REST URL and token from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://....upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# =============================================================================
# Sentry (error monitoring — optional)
# =============================================================================
# DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN="https://....ingest.sentry.io/..."
# Auth token for source-map uploads in CI
SENTRY_AUTH_TOKEN="..."
# Exposed to the browser
NEXT_PUBLIC_SENTRY_DSN="https://....ingest.sentry.io/..."
